{
  "builds": [
    {
      "src": "Portfolio-kul/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/Portfolio-kul"
      }
    }
  ],
  "outputDirectory": "Portfolio-kul/dist/Portfolio-kul",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
